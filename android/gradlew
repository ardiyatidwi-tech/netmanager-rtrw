##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell available, consider
#       using that to run this script.
#
#   (2) Avoid modifying this script unless you know what you are doing -- it's
#       just a wrapper to download and invoke the actual Gradle build script.
#
#   (3) This script is generated by the Gradle build system.
#
#   You should be careful to always run the wrapper, to ensure that you're using
#   the version of Gradle intended for this build.
#
#   If you are behind a web proxy, you may need to configure Gradle to use the
#   proxy settings. In that case, you can provide the Gradle settings like so:
#
#       -Dhttp.proxyHost=www.somehost.com
#       -Dhttp.proxyPort=8080
#       -Dhttps.proxyHost=www.somehost.com
#       -Dhttps.proxyPort=8080
#
#   In addition to the properties above, the following are also available as system
#   properties:
#
#       -Dorg.gradle.startParamFile=/path/to/gradle.properties
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

APP_NAME="Gradle"
app_base_name=${0##*/}

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS='-Xmx64m -Xms64m'

# Use the maximum available, or set MAX_FD != maximum on some systems.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
IS_CYGWIN=false
IS_MSYS=false
IS_MINGW=false
case "$( uname )" in                #(
  CYGWIN* )         IS_CYGWIN=true  ;; #(
  Darwin* )         IS_DARWIN=true  ;; #(
  MSYS* )           IS_MSYS=true    ;; #(
  MINGW* )          IS_MINGW=true   ;;
esac

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$( cd "$JAVA_HOME" && pwd -P )/jre/sh/java
    else
        JAVACMD=$( cd "$JAVA_HOME" && pwd -P )/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$mingw" ; then
    case $MAX_FD in #(
      /)
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order:
#   * args from the command line
#   * the main class name
#   * -classpath
#   * -D...sysproperties
#   * --modules-path (only if needed)
#   * DEFAULT_JVM_OPTS

for arg in "$@" ; do
    if [ "${arg}" = "--" ] ; then
        shift
        break
    fi
done

if [ "$#" -eq 0 ] ; then
    set -- --show-version
fi

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar


# Use the magically generated classpath.
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$( cd "$JAVA_HOME" && pwd -P )/jre/sh/java
    else
        JAVACMD=$( cd "$JAVA_HOME" && pwd -P )/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# executes the given command but saves the exit code as a variable.
run_die_on_nonzero() {
  if "$@" ; then
    return 0
  else
    exit 1
  fi
}

exec "$JAVACMD" $DEFAULT_JVM_OPTS -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
