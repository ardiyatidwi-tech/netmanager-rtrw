##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell available, consider
#       using that to run this script.
#
#   (2) Avoid modifying this script unless you know what you are doing -- it's
#       just a wrapper to download and invoke the actual Gradle build script.
#
#   (3) This script is generated by the Gradle build system.
#
#   You should be careful to always run the wrapper, to ensure that you're using
#   the version of Gradle intended for this build.
#
#   If you are behind a web proxy, you may need to configure Gradle to use the
#   proxy settings. In that case, you can provide the Gradle settings like so:
#
#       -Dhttp.proxyHost=www.somehost.com
#       -Dhttp.proxyPort=8080
#       -Dhttps.proxyHost=www.somehost.com
#       -Dhttps.proxyPort=8080
#
#   In addition to the properties above, the following are also available as system
#   properties:
#
#       -Dorg.gradle.startParamFile=/path/to/gradle.properties
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}	# leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

# This is normally unused
app_base_name=${0##*/}
APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

# Use the maximum available, or set MAX_FD != maximum on some systems.
MAX_FD=maximum

case $MAX_FD in #(
  /*)
    MAX_FD=$( numfds )
    ;;
esac

if [ ! -w "$APP_HOME" ]
then
    # Use the maximum available, or set MAX_FD != maximum on some systems.
    MAX_FD=maximum

    case $MAX_FD in #(
      /*)
        MAX_FD=$( numfds )
        ;;
    esac
fi

# If the caller provides no file for stdin, use /dev/null.
if [ ! -t 0 ]
then
    read -r dummy
fi

# Collect all arguments for the java command;
#   * $DEFAULT_JVM_OPTS, $JAVA_OPTS, and $GRADLE_OPTS can contain fragments of
#     shell script including quotes and variable substitutions, so put them in
#     double quotes to make sure that they get re-expanded; and
#   * put everything else in single quotes, so that it's not expanded.

set -- \
        "-Dorg.gradle.appname=$app_base_name" \
        -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" \
        org.gradle.wrapper.GradleWrapperMain \
        "$@"

# Stop when "xargs" is not available.
if ! command -v xargs >/dev/null 2>&1
then
    die "xargs not available"
fi

# Use "xargs" to parse quoted args.
#
# With -n1 it outputs one arg per line, when -0 it uses NUL characters
# as separators and allows xargs to handle arguments that contain
# whitespace. However, the number of args will often exceed the max
# limit set by xargs (which defaults to 4194304 lines for GNU xargs),
# so use the default splitting on spaces and new lines.
#
# xargs yields one arg per line, splitting on chars that are
# IFS chars [the default].
# However, this leads to incorrect handling of arguments
# like -Dorg.gradle.config.dir=/path/with spaces.
#
# Instead, use the below script to convert arguments, files, and dirs to absolute
# paths relative to the APP_HOME directory to help xargs parse the line.
for arg do
    if
        case $arg in                                #(
          -*)   false ;;                            # don't attempt to reformat options
          /?*)  true ;;                             # absolute path, keep it
          */?*) echo "$arg" | grep -q '^/' && true ;; # absolute path
          *)    false ;;                            # relative path
        esac
    then
        APP_ARGS+=( "$arg" )
    else
        APP_ARGS+=( "$(printf '%s\n' "$arg" | sed "s/^ //" | tr '\n' ' ' | sed 's/[{}|\\$`"'"'"'"\\]/\\\\&/g;s/$/\\n/;$!b' | tr -d '\n')" )
    fi
done
# Add a context object for calling the script again with the updated
# parameters later.
exec "$JAVACMD" "${JVM_OPTS[@]}" -Dorg.gradle.appname="$APP_NAME" -classpath "$classpath" org.gradle.wrapper.GradleWrapperMain "${args[@]}"
